{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": []
  },
  "JwtSettings": {
    "Issuer": "CrnProductsApi",
    "Audience": "CrnProductsApiClients",
    "Key": "dev-only-super-secret-signing-key-change-in-production-32bytes-min!!",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 7
  }
}
